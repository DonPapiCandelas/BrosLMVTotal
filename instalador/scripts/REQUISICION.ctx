cboDep.DisplayMember = "Txt";
if (almacenes.Count > 0) cboDep.SelectedIndex = 0;

x = 690;
Lbl("Fecha", x, y, cardTop);
var dtp = new DateTimePicker {
    Location = new Point(x, y + 20), Size = new Size(130, 24),
    Format = DateTimePickerFormat.Short, Value = DateTime.Today,
