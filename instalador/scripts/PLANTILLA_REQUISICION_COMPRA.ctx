// ═══════════════════ LÓGICA DE UI ═══════════════════
int DepotSel() {
    var s = cboDep.SelectedItem as Opt;
    return s != null ? s.Val : 1;
}

int ProvSel() {
    var s = cboProv.SelectedItem as Opt;
    return s != null ? s.Val : 0;
}

void ActualizarProveedorInfo() {
    var s = cboProv.SelectedItem as Opt;
    string rfc = s != null ? s.Extra : "";
    lblRfc.Text = string.IsNullOrWhiteSpace(rfc) ? "RFC: sin RFC capturado" : "RFC: " + rfc;
}

void AplicarFiltroPartidas() {
    string f = (txtFiltroPartidas.Text ?? "").Trim().ToUpperInvariant();
    gItems.CurrentCell = null;
    foreach (DataGridViewRow row in gItems.Rows) {
        string key = Convert.ToString(row.Cells["Key"].Value ?? "").ToUpperInvariant();
        string desc = Convert.ToString(row.Cells["Desc"].Value ?? "").ToUpperInvariant();
        row.Visible = f.Length == 0 || key.Contains(f) || desc.Contains(f);
    }
}

void RefreshGrid() {
    gItems.Rows.Clear();

    for (int i = 0; i < partidas.Count; i++) {
        var it = partidas[i];
        int row = gItems.Rows.Add(
            it.PID,
            false,
            it.Key,
            it.Desc,
            it.Unit,
            it.Qty,
            it.Stock,
            "Pendiente"
        );

        if (row % 2 == 0) {
            foreach (DataGridViewCell c in gItems.Rows[row].Cells)
                c.Style.BackColor = C_STRIPE;
        }
    }

    UpdateTotal();
    AplicarFiltroPartidas();
}

void UpdateTotal() {
    int n = partidas.Count;
    double total = partidas.Sum(z => z.Qty);

    lblCnt.Text = n + " producto" + (n == 1 ? "" : "s");
    lblBadgePartidas.Text = n + " partida" + (n == 1 ? "" : "s");
    lblTot.Text = total > 0 ? "  ·  Unidades solicitadas: " + total.ToString("N2") : "";
    lblTot.Location = new Point(lblCnt.Right + 4, 17);
}

void OcultarResultados() {
    pnlDrop.Visible = false;
}

void Buscar(string texto) {
    string q = (texto ?? "").Trim();

    if (q.Length == 0) {
        lstMatch.Items.Clear();
        OcultarResultados();
        return;
    }

    string safe = q.Replace("'", "''");
    string filtro = q == "#"
        ? ""
        : "AND (p.ProductKey LIKE '%" + safe + "%' OR p.ProductName LIKE '%" + safe + "%') ";
    string limite = q == "#" ? "TOP 300" : "TOP 80";

    var rows = ctx.Query(
        "SELECT " + limite + " p.ProductID, p.ProductKey, p.ProductName, p.Unit, p.TaxTypeID, " +
        "ISNULL(t.TaxTypeName,'') AS TaxTypeName, " +
        "CASE p.ProductTypeID WHEN 1 THEN 'Producto' WHEN 3 THEN 'Paquete' " +
        "WHEN 4 THEN 'Servicio' WHEN 7 THEN 'Insumo' WHEN 2 THEN 'P.Term.' " +
        "ELSE 'T'+CAST(p.ProductTypeID AS varchar) END AS Tipo, " +
        "ISNULL((SELECT SUM(Quantity) FROM orgProductKardex k " +
        "WHERE k.ProductID=p.ProductID AND k.DepotID=" + DepotSel() + " AND k.Cancelled=0),0) AS Stock " +
        "FROM orgProduct p " +
        "LEFT JOIN engTaxType t ON t.TaxTypeID=p.TaxTypeID " +
        "WHERE p.DeletedOn IS NULL " +
        "AND p.TaxTypeID IS NOT NULL AND p.TaxTypeID > 0 " +
        filtro +
        "ORDER BY p.ProductName");

    lstMatch.BeginUpdate();
    lstMatch.Items.Clear();

    foreach (var r in rows) {
        lstMatch.Items.Add(new Prod {
            PID = Convert.ToInt32(r["ProductID"]),
            Key = Convert.ToString(r["ProductKey"]),
            Desc = Convert.ToString(r["ProductName"]),
            Unit = Convert.ToString(r["Unit"]),
            TaxTypeID = Convert.ToInt32(r["TaxTypeID"] ?? 0),
            TaxName = Convert.ToString(r["TaxTypeName"]),
            Stock = Convert.ToDouble(r["Stock"] ?? 0),
            Tipo = Convert.ToString(r["Tipo"])
        });
    }

    lstMatch.EndUpdate();

    if (lstMatch.Items.Count == 0) {
        lblProductoInfo.Text = "No se encontraron productos con esa búsqueda.";
        lblProductoInfo.ForeColor = C_DANGER;
        OcultarResultados();
        return;
    }

    lstMatch.SelectedIndex = 0;

    int alto = Math.Min(lstMatch.Items.Count * lstMatch.ItemHeight + 4, 286);
    int posX = cardAdd.Left + txtProducto.Left;
    int posY = cardAdd.Top + txtProducto.Bottom + 2;
    int ancho = Math.Min(cardAdd.Width - txtProducto.Left - 16, 880);

    pnlDrop.SetBounds(posX, posY, ancho, alto);
    pnlDrop.Visible = true;
    pnlDrop.BringToFront();

    lblProductoInfo.Text = lstMatch.Items.Count + " resultado" + (lstMatch.Items.Count == 1 ? "" : "s") +
        " · usa flechas y Enter para seleccionar.";
    lblProductoInfo.ForeColor = C_MUTED;
}

void SeleccionarProducto() {
    var p = lstMatch.SelectedItem as Prod;
    if (p == null) return;

    productoSeleccionado = p;

    suspenderBusqueda = true;
    txtProducto.Text = p.Key + " — " + p.Desc;
    txtProducto.SelectionStart = txtProducto.TextLength;
    suspenderBusqueda = false;

    lblProductoInfo.Text =
        "Seleccionado: " + p.Key + " · Unidad: " + p.Unit +
        " · Existencia: " + p.Stock.ToString("N2");
    lblProductoInfo.ForeColor = C_SUCCESS;

    OcultarResultados();
    nudCantidad.Focus();
}

void LimpiarCapturaProducto() {
    productoSeleccionado = null;

    suspenderBusqueda = true;
    txtProducto.Clear();
    suspenderBusqueda = false;

    nudCantidad.Value = 1M;
    lblProductoInfo.Text =
        "Escribe al menos parte de la clave o descripción; también puedes abrir el catálogo completo.";
    lblProductoInfo.ForeColor = C_MUTED;
    OcultarResultados();
}

void AgregarProducto() {
    if (productoSeleccionado == null) {
        if (pnlDrop.Visible && lstMatch.SelectedItem != null) {
            SeleccionarProducto();
        } else {
            ctx.Msg("Busca y selecciona un producto antes de agregarlo.");
            txtProducto.Focus();
            return;
        }
    }

    double cantidad = Convert.ToDouble(nudCantidad.Value);
    if (cantidad <= 0) {
        ctx.Msg("La cantidad debe ser mayor que cero.");
        nudCantidad.Focus();
        return;
    }

    var p = productoSeleccionado;
    var existente = partidas.FirstOrDefault(z => z.PID == p.PID);

    if (existente != null) {
        existente.Qty += cantidad;
    } else {
        partidas.Add(new Item {
            PID = p.PID,
            Key = p.Key,
            Desc = p.Desc,
            Unit = p.Unit,
            TaxTypeID = p.TaxTypeID,
            TaxName = p.TaxName,
            Qty = cantidad,
            Stock = p.Stock,
            Tipo = p.Tipo
        });
    }

    RefreshGrid();
    LimpiarCapturaProducto();
    txtProducto.Focus();
}

// ─── EVENTOS DE BÚSQUEDA Y CAPTURA ─────────────────
txtProducto.TextChanged += (_, __) => {
    if (suspenderBusqueda) return;
    productoSeleccionado = null;
    Buscar(txtProducto.Text);
};

btnCatalogo.Click += (_, __) => {
    productoSeleccionado = null;
    txtProducto.Focus();
    Buscar("#");
};

btnAvanzada.Click += (_, __) => {
    productoSeleccionado = null;
    txtProducto.Focus();
    Buscar("#");
};

cboProv.SelectedIndexChanged += (_, __) => ActualizarProveedorInfo();

txtFiltroPartidas.TextChanged += (_, __) => AplicarFiltroPartidas();
btnFiltrar.Click += (_, __) => AplicarFiltroPartidas();
btnImportar.Click += (_, __) =>
    ctx.Msg("Importar partidas queda como punto de extension de la plantilla.");

btnAgregar.Click += (_, __) => AgregarProducto();

lstMatch.MouseDoubleClick += (_, __) => SeleccionarProducto();

lstMatch.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Enter) {
        SeleccionarProducto();
        ev.Handled = true;
    } else if (ev.KeyCode == Keys.Escape) {
        OcultarResultados();
        txtProducto.Focus();
        ev.Handled = true;
    }
};

txtProducto.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Down && pnlDrop.Visible) {
        lstMatch.Focus();
        if (lstMatch.SelectedIndex < 0 && lstMatch.Items.Count > 0)
            lstMatch.SelectedIndex = 0;
        ev.Handled = true;
    } else if (ev.KeyCode == Keys.Enter) {
        if (pnlDrop.Visible && lstMatch.SelectedItem != null)
            SeleccionarProducto();
        else if (productoSeleccionado != null)
            AgregarProducto();
        ev.Handled = true;
        ev.SuppressKeyPress = true;
    } else if (ev.KeyCode == Keys.Escape) {
        LimpiarCapturaProducto();
        ev.Handled = true;
    }
};

nudCantidad.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Enter) {
        AgregarProducto();
        ev.Handled = true;
        ev.SuppressKeyPress = true;
    }
};

cboDep.SelectedIndexChanged += (_, __) => {
    if (!string.IsNullOrWhiteSpace(txtProducto.Text) && productoSeleccionado == null)
        Buscar(txtProducto.Text);
};

frm.Deactivate += (_, __) => OcultarResultados();

// ─── EDICIÓN DE CANTIDAD EN GRID ────────────────────
gItems.CellEndEdit += (_, ev) => {
    if (ev.RowIndex < 0 || ev.RowIndex >= partidas.Count) return;
    if (gItems.Columns[ev.ColumnIndex].Name != "Qty") return;

    var it = partidas[ev.RowIndex];
    double valor = it.Qty;

    try {
        valor = Convert.ToDouble(gItems.Rows[ev.RowIndex].Cells["Qty"].Value ?? it.Qty);
    } catch {
        valor = it.Qty;
    }

    if (valor <= 0) valor = 1;
    it.Qty = valor;
    gItems.Rows[ev.RowIndex].Cells["Qty"].Value = valor;
    UpdateTotal();
};

gItems.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Delete && gItems.CurrentRow != null) {
        int i = gItems.CurrentRow.Index;
        if (i >= 0 && i < partidas.Count) {
            partidas.RemoveAt(i);
            RefreshGrid();
        }
        ev.Handled = true;
    }
};

// ─── BOTONES INFERIORES ─────────────────────────────
btnLimp.Click += (_, __) => {
    if (partidas.Count == 0) return;
    if (ctx.Confirm("¿Limpiar todas las partidas agregadas?")) {
        partidas.Clear();
        RefreshGrid();
        LimpiarCapturaProducto();
    }
};

btnQuitar.Click += (_, __) => {
    if (gItems.CurrentRow == null) return;

    int i = gItems.CurrentRow.Index;
    if (i < 0 || i >= partidas.Count) return;

    var it = partidas[i];
    if (ctx.Confirm("¿Quitar la partida " + it.Key + "?")) {
        partidas.RemoveAt(i);
        RefreshGrid();
    }
};

// ═══════════════════ CREAR REQUISICION ══════════════
btnOK.Click += (_, __) => {
    int be = ProvSel();
    if (be == 0) {
        ctx.Msg("Selecciona un proveedor.");
        return;
    }

    if (partidas.Count == 0) {
        ctx.Msg("Agrega al menos un producto.");
        txtProducto.Focus();
        return;
    }

    long supplierID = Convert.ToInt64(ctx.Scalar(
        "SELECT SupplierID FROM orgSupplier WHERE BusinessEntityID=" + be));

    if (!ctx.Confirm(
        "Crear requisición de compra con " + partidas.Count + " producto" +
        (partidas.Count == 1 ? "" : "s") + "?")) return;

    frm.Cursor = Cursors.WaitCursor;
    btnOK.Enabled = false;
    btnOK.Text = "Creando...";

    try {
        int dep = DepotSel();
        ctx.Log("REQ be=" + be + " dep=" + dep + " supplier=" + supplierID + " items=" + partidas.Count);

        ctx.NonQuery("SET XACT_ABORT OFF; SET IMPLICIT_TRANSACTIONS OFF");

        int doc = ctx.erp.NuevoDocumento(1040, dep, be);
        if (doc <= 0 || !string.IsNullOrEmpty(ctx.erp.LastError))
            throw new Exception("NuevoDocumento: " + (ctx.erp.LastError ?? "doc=" + doc));

        ctx.NonQuery(
            "UPDATE docDocument SET DepotIDFrom=0, UserID=0, " +
            "CampaignID=NULL, CostCenterID=NULL, ProjectID=NULL, PaymentTermID=0 " +
            "WHERE DocumentID=" + doc);

        foreach (var it in partidas) {
            ctx.erp.AgregarArticulo(doc, it.PID, it.Qty);
            if (!string.IsNullOrEmpty(ctx.erp.LastError))
                throw new Exception("AgregarArticulo PID=" + it.PID + ": " + ctx.erp.LastError);
        }

        foreach (var it in partidas) {
            ctx.NonQuery(
                "IF NOT EXISTS (SELECT 1 FROM orgProductSupplier " +
                "WHERE ProductID=" + it.PID + " AND SupplierID=" + supplierID + ") " +
                "INSERT INTO orgProductSupplier " +
                "(ProductID, SupplierID, CostPrice, CurrencyID, RefSupplier, OrderNumber) " +
                "VALUES (" + it.PID + ", " + supplierID + ", 0, 3, NULL, 0)");
        }

        ctx.erp.RecalcCompleto(doc);
        if (!string.IsNullOrEmpty(ctx.erp.LastError))
            throw new Exception("RecalcCompleto: " + ctx.erp.LastError);

        ctx.erp.Save(doc);
        if (!string.IsNullOrEmpty(ctx.erp.LastError))
            throw new Exception("Save: " + ctx.erp.LastError);

        try { ctx.erp.RefreshGrid(); } catch { }

        ctx.Log("REQ-OK doc=" + doc);
        ctx.Msg(
            "Requisición de compra " + doc + " creada.\n" + partidas.Count + " productos.",
            "OK");
        frm.Close();
    } catch (Exception ex) {
        ctx.Log("ERROR REQ: " + ex.Message);
        ctx.Msg(ex.Message, "Error");
    } finally {
        frm.Cursor = Cursors.Default;
        btnOK.Enabled = true;
        btnOK.Text = "Crear requisición";
    }
};

// ═══════════════════ HELPERS ═══════════════════
Label Lbl(string texto, int px, int py, Control padre) {
    return new Label {
        Text = texto,
        Location = new Point(px, py),
        Font = F_H2,
        ForeColor = C_TEXT,
        AutoSize = true,
        Parent = padre
    };
}

ComboBox Cbo(int px, int py, int ancho, int altoLista, Control padre) {
    return new ComboBox {
        Location = new Point(px, py),
        Size = new Size(ancho, 25),
        DropDownStyle = ComboBoxStyle.DropDownList,
        DropDownHeight = Math.Max(altoLista, 250),
        Font = F_BODY,
        FlatStyle = FlatStyle.Flat,
        BackColor = C_WHITE,
        Parent = padre
    };
}

void DrawBorder(Control c) {
    c.Paint += (_, ev) => {
        using (var pen = new Pen(C_BORDER, 1))
            ev.Graphics.DrawRectangle(pen, 0, 0, c.Width - 1, c.Height - 1);
    };
}

DataGridViewTextBoxColumn GridCol(
    DataGridView g,
    string name,
    string header,
    int width,
    bool readOnly,
    DataGridViewContentAlignment? alignment = null,
    string format = null,
    bool visible = true)
{
    var col = new DataGridViewTextBoxColumn {
        Name = name,
        HeaderText = header,
        Width = width,
        ReadOnly = readOnly,
        Visible = visible
    };

    if (alignment != null)
        col.DefaultCellStyle.Alignment = alignment.Value;
    if (format != null)
        col.DefaultCellStyle.Format = format;

    g.Columns.Add(col);
    return col;
}

class Opt {
    public string Txt;
    public int Val;
    public string Extra;

    public Opt(string texto, int valor) {
        Txt = texto;
        Val = valor;
        Extra = "";
    }

    public Opt(string texto, int valor, string extra) {
        Txt = texto;
        Val = valor;
        Extra = extra ?? "";
    }

    public override string ToString() {
        return Txt;
    }
}

class Item {
    public int PID;
    public int TaxTypeID;
    public string Key = "";
    public string Desc = "";
    public string Unit = "";
    public string TaxName = "";
    public string Tipo = "";
    public double Qty = 1;
    public double Stock = 0;
}

class Prod {
    public int PID;
    public int TaxTypeID;
    public string Key = "";
    public string Desc = "";
    public string Unit = "";
    public string TaxName = "";
    public string Tipo = "";
    public double Stock = 0;

    public override string ToString() {
        string stock = Tipo == "Servicio"
            ? "SERVICIO"
            : "EXIST: " + Stock.ToString("N2");

        return (Key ?? "") + " - " + (Desc ?? "") + " - " + (Unit ?? "") + " - " + stock;
    }
}

ActualizarProveedorInfo();
RefreshGrid();
txtProducto.Focus();
frm.ShowDialog();
