int rb = cardFoot.Width - 14;
Button MakeBtn(string texto, int ancho, Color fondo, Color textoColor, bool principal) {
    rb -= ancho + 6;
    var b = new Button {
        Text = texto,
        FlatStyle = FlatStyle.Flat,
        Location = new Point(rb, 10),
        Size = new Size(ancho, 30),
        Font = F_BTN,
        Cursor = Cursors.Hand,
        Parent = cardFoot,
        TextAlign = ContentAlignment.MiddleCenter,
        ForeColor = textoColor,
        BackColor = fondo
    };
    b.FlatAppearance.BorderSize = principal ? 0 : 1;
    b.FlatAppearance.BorderColor = principal ? fondo : C_BORDER;
    return b;
}

