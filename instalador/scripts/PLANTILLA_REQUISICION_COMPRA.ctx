    Visible = false,
    BackColor = C_BORDER,
    Padding = new Padding(1),
    Parent = frm
};

var lstMatch = new ListBox {
    Visible = true,
    Dock = DockStyle.Fill,
    Font = F_BODY,
    BorderStyle = BorderStyle.None,
    IntegralHeight = false,
    BackColor = C_WHITE,
    ForeColor = C_TEXT,
    DrawMode = DrawMode.OwnerDrawFixed,
    ItemHeight = 50,
    Parent = pnlDrop
};

lstMatch.DrawItem += (_, ev) => {
    if (ev.Index < 0) return;

    var p = lstMatch.Items[ev.Index] as Prod;
    bool sel = (ev.State & DrawItemState.Selected) == DrawItemState.Selected;
    Color bg = sel ? C_BLUE_SEL : C_WHITE;
    Color fg = C_TEXT;

    using (var br = new SolidBrush(bg))
        ev.Graphics.FillRectangle(br, ev.Bounds);

    if (p == null) return;

    var r = ev.Bounds;
    int left = r.Left + 10;
    int top = r.Top + 6;

    using (var brText = new SolidBrush(fg))
    using (var brMuted = new SolidBrush(C_MUTED))
    using (var brBadge = new SolidBrush(C_BADGE_BG))
    using (var pen = new Pen(C_BORDER))
    using (var keyFont = new Font("Segoe UI", 9f, FontStyle.Bold))
    using (var badgeFont = new Font("Segoe UI", 8f, FontStyle.Bold)) {
        var descRect = new RectangleF(left + 118, top, Math.Max(180, r.Width - 230), 18);
        var metaRect = new RectangleF(left + 118, top + 22, Math.Max(180, r.Width - 230), 18);
        ev.Graphics.DrawString(p.Key, keyFont, brText, left, top);
        ev.Graphics.DrawString(p.Desc, F_BODY, brText, descRect);

        string stock = p.Tipo == "Servicio"
            ? "Servicio"
            : "Existencia " + p.Stock.ToString("N2");
        string meta = "Unidad " + p.Unit + " · " + stock;
        ev.Graphics.DrawString(meta, F_SM, brMuted, metaRect);

        var badge = new Rectangle(r.Right - 98, r.Top + 13, 82, 22);
        ev.Graphics.FillRectangle(brBadge, badge);
        ev.Graphics.DrawRectangle(pen, badge);
        using (var sf = new StringFormat { Alignment = StringAlignment.Center, LineAlignment = StringAlignment.Center })
            ev.Graphics.DrawString(p.Tipo, badgeFont, brMuted, badge, sf);
    }

    ev.DrawFocusRectangle();
};

