#r "System.Windows.Forms"
#r "System.Drawing"
#r "System.Data"
#r "Microsoft.CSharp"

// PLANTILLA_REQUISICION_COMPRA.ctx
// Ejemplo comunitario completo: crea una Solicitud de Compra real (modulo 1040).
//
// Que ensena esta plantilla:
// 1. Como construir una ventana WinForms dentro de la consola BrosLMV.
// 2. Como leer proveedores, almacenes y productos con ctx.Query.
// 3. Como crear el documento con ctx.erp.NuevoDocumento, no con INSERT manual.
// 4. Como agregar partidas con ctx.erp.AgregarArticulo.
// 5. Como aplicar solo el SQL directo necesario: perfil modulo 1040 y orgProductSupplier.
// 6. Como cerrar el documento con ctx.erp.RecalcCompleto, ctx.erp.Save y ctx.erp.RefreshGrid.
//
// Regla de fidelidad:
// La solicitud de compra NO afecta inventario; por eso este script NO llama AffectStockNEW.
//
// Nota para quien adapte:
// El bloque importante para aprender la creacion del documento esta en la seccion
// "CREAR REQUISICION", cerca del final del archivo. La UI solo recolecta los datos.

using System;
using System.Collections.Generic;
using System.Data;
