// lang: csharp
using System;
using System.Drawing;
using System.Windows.Forms;
using System.Collections.Generic;
using System.Linq;

// PLANTILLA_EJEMPLO_RECEPCION_COMPRA_CSHARP.ctx
// Ejemplo comunitario completo: crea una Recepción de Compra (módulo 184) a partir de una o
// varias Órdenes de Compra (módulo 183) del MISMO proveedor.
//
// Diferencia clave frente a la Orden de Compra: una Recepción de Compra SÍ afecta inventario
// (StockAffectation=3 en la config del módulo) -- por eso este script SÍ llama AffectStockNEW,
// a diferencia del ejemplo de Orden de Compra. Además, no se captura "de cero": las partidas
// vienen de lo que quedó PENDIENTE de recibir en una o varias OC ya existentes.
//
// N Órdenes de Compra -> 1 Recepción: CONTPAQi rastrea "cuánto se ha recibido" de forma nativa
// usando docDocument.SourceDocumentID (un solo valor por ENCABEZADO de Recepción) -- eso alcanza
// para 1 OC por Recepción, pero no para varias. Por eso aquí NO se usa esa vista nativa
// (vwLBSProductsToDeliver/vwLBSProductsDelivered) para calcular pendientes: se hace un cálculo
// PROPIO basado en docDocumentItem.DeliverDocumentItemID (a nivel de PARTIDA, no de documento),
// que si soporta que una Recepción reciba de varias OC distintas. Ver MANUAL.md #11 para el
// patrón completo explicado.
//
// Regla de fidelidad: este script NO copia nada de terceros -- el cálculo de pendientes y el
// alta de la Recepción se construyeron desde el esquema real (ingeniería inversa propia).

// ═══════════════════ DATOS INICIALES ═══════════════════
var almacenes = ctx.Query("SELECT DepotID, DepotName FROM orgDepot WHERE DeletedOn IS NULL ORDER BY DepotName");

// Proveedores con AL MENOS una Orden de Compra activa (puede que ya no tengan nada pendiente;
// se filtra de verdad al calcular pendientes por proveedor, más abajo).
var proveedoresConOC = ctx.Query(@"
    SELECT DISTINCT be.BusinessEntityID, be.OfficialName, ISNULL(m.OfficialNumber,'') AS RFC
    FROM docDocument d
    INNER JOIN docDocumentItem i ON i.DocumentID = d.DocumentID AND i.DeletedOn IS NULL AND i.MustBeDelivered <> 0
    INNER JOIN orgBusinessEntity be ON be.BusinessEntityID = d.BusinessEntityID
    LEFT JOIN orgBusinessEntityMainInfo m ON m.BusinessEntityID = be.BusinessEntityID
    WHERE d.ModuleID = 183 AND d.DeletedOn IS NULL AND d.CancelledOn IS NULL
    ORDER BY be.OfficialName");

var ocsPendientes = new List<OcPendiente>();          // Órdenes de compra pendientes del proveedor activo
var partidasARecibir = new List<PartidaConsolidada>(); // Partidas consolidadas por producto (pueden venir de varias OC)
var provAll = new List<Opt>();

