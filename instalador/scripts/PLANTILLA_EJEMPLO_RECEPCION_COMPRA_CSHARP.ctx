DataGridViewColumn Col(string name, string header, int width, bool readOnly, DataGridViewContentAlignment align = DataGridViewContentAlignment.MiddleLeft, string fmt = null, bool chk = false) {
    DataGridViewColumn c = chk
        ? new DataGridViewCheckBoxColumn { Name = name, HeaderText = header, Width = width }
        : new DataGridViewTextBoxColumn { Name = name, HeaderText = header, Width = width, ReadOnly = readOnly };
    if (!chk) { c.DefaultCellStyle.Alignment = align; if (fmt != null) c.DefaultCellStyle.Format = fmt; }
    grid.Columns.Add(c);
    return c;
}
