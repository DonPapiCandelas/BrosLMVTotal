// ═══════════════════ NÚMERO A LETRAS ═══════════════════
string[] UNIDADES = { "", "UNO", "DOS", "TRES", "CUATRO", "CINCO", "SEIS", "SIETE", "OCHO", "NUEVE", "DIEZ",
    "ONCE", "DOCE", "TRECE", "CATORCE", "QUINCE", "DIECISÉIS", "DIECISIETE", "DIECIOCHO", "DIECINUEVE", "VEINTE" };
string[] DECENAS = { "", "", "VEINTE", "TREINTA", "CUARENTA", "CINCUENTA", "SESENTA", "SETENTA", "OCHENTA", "NOVENTA" };
string[] VEINTI = { "VEINTIUNO", "VEINTIDÓS", "VEINTITRÉS", "VEINTICUATRO", "VEINTICINCO", "VEINTISÉIS", "VEINTISIETE", "VEINTIOCHO", "VEINTINUEVE" };
string[] CENTENAS = { "", "CIENTO", "DOSCIENTOS", "TRESCIENTOS", "CUATROCIENTOS", "QUINIENTOS",
    "SEISCIENTOS", "SETECIENTOS", "OCHOCIENTOS", "NOVECIENTOS" };
string Centenas_(int n) {
    if (n == 0) return "";
    if (n == 100) return "CIEN";
    string s = "";
    int c = n / 100, r = n % 100;
    if (c > 0) s += CENTENAS[c] + " ";
    if (r > 0) {
        if (r <= 20) s += UNIDADES[r];
        else {
            int d = r / 10, u = r % 10;
            if (d == 2 && u > 0) s += VEINTI[u - 1];
            else { s += DECENAS[d]; if (u > 0) s += " Y " + UNIDADES[u]; }
        }
    }
    return s.Trim();
}
string EnLetras(long n) {
    if (n == 0) return "CERO";
    string resultado = "";
    long millones = n / 1000000; n %= 1000000;
    long miles = n / 1000; n %= 1000;
    long resto = n;
    if (millones > 0) resultado += (millones == 1 ? "UN MILLÓN " : Centenas_((int)millones) + " MILLONES ");
    if (miles > 0) resultado += (miles == 1 ? "MIL " : Centenas_((int)miles) + " MIL ");
    if (resto > 0) resultado += Centenas_((int)resto);
    resultado = resultado.Trim();
    if (resultado.EndsWith("UNO")) resultado = resultado.Substring(0, resultado.Length - 3) + "UN";
    return resultado;
}
string NumeroALetras(double valor) {
    if (valor < 0) valor = 0;
    long entero = (long)Math.Floor(valor);
    int centavos = (int)Math.Round((valor - entero) * 100);
    return EnLetras(entero) + " PESOS " + centavos.ToString("00") + "/100";
}

// ═══════════════════ LÓGICA CORE ═══════════════════
void PrecargarFolio() {
    try {
        string pre = ctx.erp.GetFolioPrefix(152, depotOrigen);
        string fol = ctx.erp.GetNextFolio(152, pre, depotOrigen);
        txtSerie.Text = pre ?? "";
        txtFolio.Text = fol ?? "";
    } catch { txtSerie.Text = "FC"; txtFolio.Text = ""; }
}

// Cálculo PROPIO de "cuánto de esta partida de OC ya se facturó" -- igual que en Recepción de
// Compra pero usando docDocumentItem.SourceDocumentItemID (el campo que copia el nativo al
// transformar OC->FC), contra facturas de compra (ModuleID=152) ya guardadas. Consolida por
// producto entre las OC seleccionadas, igual que en Recepción.
void CargarPartidasPendientes() {
    List<Dictionary<string, object>> rows;
    try {
        rows = ctx.Query(
            "SELECT d.DocumentID, d.FolioPrefix, d.Folio, " +
            "i.DocumentItemID, i.ProductID, ISNULL(p.ProductKey, i.ProductKey) AS ProductKey, " +
            "ISNULL(p.ProductName, i.Description) AS ProductName, i.Unit, i.TaxTypeID, i.TaxPerc, " +
            "i.UnitPrice, i.DiscountPerc, i.Quantity AS Ordenado, " +
            "ISNULL((SELECT SUM(fi.Quantity) FROM docDocumentItem fi " +
            "        INNER JOIN docDocument fd ON fd.DocumentID = fi.DocumentID " +
            "        WHERE fi.SourceDocumentItemID = i.DocumentItemID AND fi.DeletedOn IS NULL " +
            "          AND fd.DeletedOn IS NULL AND fd.CancelledOn IS NULL), 0) AS YaFacturado " +
            "FROM docDocumentItem i " +
            "INNER JOIN docDocument d ON d.DocumentID = i.DocumentID " +
            "LEFT JOIN orgProduct p ON p.ProductID = i.ProductID " +
            "WHERE d.DocumentID IN (" + ctx.JoinIds(idsSeleccionados) + ") " +
            "  AND i.DeletedOn IS NULL AND i.ProductID > 0 " +
            "ORDER BY d.DocumentID, i.LineNumber");
    } catch (Exception ex) {
        ctx.Msg("Error al calcular pendientes de facturar: " + ex.Message, "Error");
        return;
    }

    var porProducto = new Dictionary<int, PartidaConsolidada>();
    var ocFolioPorId = ocsSeleccionadas.ToDictionary(
        r => Convert.ToInt32(r["DocumentID"]),
        r => Convert.ToString(r["FolioPrefix"]) + Convert.ToString(r["Folio"]));

    foreach (var r in rows) {
        double ordenado = Convert.ToDouble(r["Ordenado"] ?? 0);
        double yaFacturado = Convert.ToDouble(r["YaFacturado"] ?? 0);
        double pendiente = ordenado - yaFacturado;
        if (pendiente <= 0.0001) continue; // ya se facturó completo esta partida

        int pid = Convert.ToInt32(r["ProductID"]);
        int docId = Convert.ToInt32(r["DocumentID"]);
        var fuenteItem = new Item {
            PID = pid,
            SourceItemId = Convert.ToInt32(r["DocumentItemID"]),
            OcFolio = ocFolioPorId.ContainsKey(docId) ? ocFolioPorId[docId] : ("Doc " + docId),
            Key = Convert.ToString(r["ProductKey"]),
            Desc = Convert.ToString(r["ProductName"]),
            Unit = Convert.ToString(r["Unit"]),
            TaxTypeId = Convert.ToInt32(r["TaxTypeID"] ?? 0),
            TaxPerc = Convert.ToDouble(r["TaxPerc"] ?? 0),
            Precio = Convert.ToDouble(r["UnitPrice"] ?? 0),
            DescuentoPerc = Convert.ToDouble(r["DiscountPerc"] ?? 0),
            Pendiente = pendiente
        };

        if (!porProducto.TryGetValue(pid, out var pc)) {
            pc = new PartidaConsolidada {
                PID = pid, Key = fuenteItem.Key, Desc = fuenteItem.Desc, Unit = fuenteItem.Unit,
                TaxTypeId = fuenteItem.TaxTypeId, TaxPerc = fuenteItem.TaxPerc, Precio = fuenteItem.Precio,
                DescuentoPerc = fuenteItem.DescuentoPerc
            };
            porProducto[pid] = pc;
        }
        pc.Fuentes.Add(fuenteItem);
    }

    partidasAFacturar.Clear();
    foreach (var pc in porProducto.Values) {
        pc.Pendiente = pc.Fuentes.Sum(f => f.Pendiente);
        pc.Qty = pc.Pendiente;
        pc.OcsResumen = string.Join(", ", pc.Fuentes.Select(f => f.OcFolio).Distinct());
        partidasAFacturar.Add(pc);
    }
    RefreshGrid();
}

void RefreshGrid() {
    grid.Rows.Clear();
    double subtotal = 0, descuentoTotal = 0, impuestosTotal = 0;
    foreach (var it in partidasAFacturar) {
        double importe = it.Qty * it.Precio;
        double descMonto = importe * it.DescuentoPerc;
        double neto = importe - descMonto;
        double impMonto = neto * it.TaxPerc;
        double totalLinea = neto + impMonto;
        subtotal += importe; descuentoTotal += descMonto; impuestosTotal += impMonto;

        int i = grid.Rows.Add(true, it.PID, it.OcsResumen, it.Key, it.Desc, it.Unit, it.Pendiente, it.Qty,
            it.Precio, null, it.DescuentoPerc * 100, importe, impMonto, totalLinea);
        var impOpt = (grid.Columns["Impuesto"] as DataGridViewComboBoxColumn)?.Items.Cast<Opt>().FirstOrDefault(o => o.Val == it.TaxTypeId);
        grid.Rows[i].Cells["Impuesto"].Value = impOpt;
    }
    lblPartVacio.Visible = partidasAFacturar.Count == 0;
    lblPartVacio.Text = "No hay partidas pendientes de facturar en las Órdenes de Compra seleccionadas.";

    double granTotal = subtotal - descuentoTotal + impuestosTotal;
    lblTSubtotal.Text = "$" + subtotal.ToString("N2");
    lblTDescuento.Text = "-$" + descuentoTotal.ToString("N2");
    lblTImpuestos.Text = "$" + impuestosTotal.ToString("N2");
    lblTTotal.Text = "$" + granTotal.ToString("N2");
    lblTotalLetra.Text = "SON: " + NumeroALetras(granTotal) + " M.N.";
}

// Regenera la agenda de pago con los MONTOS REALES según la condición de pago elegida.
// OJO (hallazgo del laboratorio, EXP-DOC-factura_compra_001): NuevoDocumento crea un
// PaymentAgenda placeholder (Amount=0) que Save() no corrige -- Save regenera desde el caché
// interno de XEngine, no desde la BD, así que queda con montos inválidos si no se hace esto.
void RegenerarPaymentAgenda(int doc, int paymentTermId) {
    double total = Convert.ToDouble(ctx.Scalar("SELECT Total FROM docDocument WHERE DocumentID=" + doc) ?? 0);
    var detalle = ctx.Query("SELECT PaymentPerc, PaymentUnit, PaymentPeriod FROM engPaymentTermDetail WHERE PaymentTermID=" + paymentTermId + " ORDER BY PaymentTermDetailID");
    if (detalle.Count == 0) return; // condición sin detalle configurado: se deja el placeholder tal cual

    ctx.NonQuery("UPDATE docDocumentPaymentAgenda SET DeletedOn=GETDATE() WHERE DeletedOn IS NULL AND DocumentID=" + doc);
    int numero = 1;
    foreach (var d in detalle) {
        double perc = Convert.ToDouble(d["PaymentPerc"] ?? 0);
        int unidad = Convert.ToInt32(d["PaymentUnit"] ?? 1);
        int periodo = Convert.ToInt32(d["PaymentPeriod"] ?? 0);
        // PaymentUnit visto en captura real: 1=días/inmediato, 2=semanas, 3=meses.
        string expresionFecha = unidad == 3 ? "DATEADD(MONTH," + periodo + ",GETDATE())"
                              : unidad == 2 ? "DATEADD(DAY," + (periodo * 7) + ",GETDATE())"
                              : "DATEADD(DAY," + periodo + ",GETDATE())";
        double monto = total * perc / 100.0;
        ctx.NonQuery(
            "INSERT INTO docDocumentPaymentAgenda (DocumentID, DatePayment, TotalPerc, Amount, PartialityNumber, CreatedOn, CreatedBy) VALUES (" +
            doc + ", " + expresionFecha + ", " + perc.ToString(System.Globalization.CultureInfo.InvariantCulture) + ", " +
            monto.ToString(System.Globalization.CultureInfo.InvariantCulture) + ", " + numero + ", GETDATE(), " + ctx.UserID + ")");
        numero++;
    }
}

void LimpiarTodo() {
    foreach (var it in partidasAFacturar) it.Qty = it.Pendiente;
    RefreshGrid();
    txtObs.Clear();
}

// ═══════════════════ CREAR EN CONTPAQi ═══════════════════
void CrearFactura() {
    if (partidasAFacturar.Count == 0 || partidasAFacturar.All(p => p.Qty <= 0)) {
        ctx.Msg("Marca al menos una partida con cantidad a facturar mayor a 0."); return;
    }
    foreach (var it in partidasAFacturar) {
        if (it.Qty > it.Pendiente + 0.0001) {
            ctx.Msg("La cantidad a facturar de \"" + it.Desc + "\" (" + it.Qty.ToString("N2") + ") no puede ser mayor a lo pendiente (" + it.Pendiente.ToString("N2") + ").", "Cantidad inválida");
            return;
        }
    }
    var condSel = cboCond.SelectedItem as Opt;
    int condId = condSel?.Val ?? 1;

    if (!ctx.Confirm("¿Crear factura de compra con " + partidasAFacturar.Count(p => p.Qty > 0) + " partida(s)?")) return;

    frm.Cursor = Cursors.WaitCursor;
    var btnG = toolButtons["guardar"]; btnG.Enabled = false;
    try {
        int doc = ctx.erp.NuevoDocumento(152, depotOrigen, proveedorBE); // 152 = Factura de Compra
        if (doc <= 0 || !string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("NuevoDocumento: " + ctx.erp.LastError);

        // Perfil de encabezado confirmado en EXP-DOC-factura_compra_001: DepotIDFrom=0,
        // StatusDeliveryID=0 (NO 3 como la OC), Campaign/CostCenter/Project=NULL.
        string folioManual = (txtFolio.Text ?? "").Trim();
        ctx.NonQuery(
            "UPDATE docDocument SET DepotIDFrom=0, UserID=0, PaymentTermID=" + condId + ", StatusDeliveryID=0, " +
            "CampaignID=NULL, CostCenterID=NULL, ProjectID=NULL, " +
            "DateDocument='" + dtFecha.Value.ToString("yyyyMMdd") + "', DateDelivery=GETDATE(), " +
            "Comments='" + txtObs.Text.Replace("'", "''") + "'" +
            (folioManual.Length > 0 ? ", Folio=N'" + folioManual.Replace("'", "''") + "'" : "") +
            " WHERE DocumentID=" + doc);

        // Reparte la cantidad consolidada entre sus OC de origen (la más antigua primero) para
        // que cada partida lleve el SourceDocumentItemID correcto de SU partida de OC.
        foreach (var pc in partidasAFacturar.Where(p => p.Qty > 0)) {
            double restante = pc.Qty;
            foreach (var fuente in pc.Fuentes) {
                if (restante <= 0.0001) break;
                double aFacturarDeEsta = Math.Min(restante, fuente.Pendiente);
                if (aFacturarDeEsta <= 0.0001) continue;

                int itemId = ctx.erp.AgregarArticulo(doc, pc.PID, aFacturarDeEsta, pc.Precio, -1, pc.TaxTypeId, pc.DescuentoPerc,
                    fuente.SourceItemId);
                if (!string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("AgregarArticulo: " + ctx.erp.LastError);

                restante -= aFacturarDeEsta;
            }
        }

        // Relación producto-proveedor (igual que OC/RC).
        long supplierID = Convert.ToInt64(ctx.Scalar("SELECT SupplierID FROM orgSupplier WHERE BusinessEntityID=" + proveedorBE));
        foreach (var pid in partidasAFacturar.Where(p => p.Qty > 0).Select(p => p.PID).Distinct())
            ctx.NonQuery(
                "IF NOT EXISTS (SELECT 1 FROM orgProductSupplier WHERE ProductID=" + pid + " AND SupplierID=" + supplierID + ") " +
                "INSERT INTO orgProductSupplier (ProductID, SupplierID, CostPrice, CurrencyID, OrderNumber) VALUES (" + pid + ", " + supplierID + ", 0, 3, 0)");

        ctx.erp.RecalcCompleto(doc);
        if (!string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("RecalcCompleto: " + ctx.erp.LastError);
        // Factura de Compra NO afecta inventario -- SIN AffectStockNEW (a diferencia de Recepción).
        ctx.erp.Save(doc);
        if (!string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("Save: " + ctx.erp.LastError);
        // Save() ya generó la póliza contable (accPoliza/accPolizaTransaccion) automáticamente
        // -- no hace falta tocarla. Pero el PaymentAgenda SÍ necesita regenerarse a mano.
        try { RegenerarPaymentAgenda(doc, condId); } catch (Exception exPA) { ctx.Msg("La factura se creó, pero no se pudo regenerar la agenda de pago: " + exPA.Message, "Aviso"); }
        try { ctx.erp.RefreshGrid(); } catch { }

        ctx.Msg("Factura de compra " + doc + " creada exitosamente.", "OK");
        frm.Close();
    } catch (Exception ex) {
        ctx.Msg(ex.Message, "Error");
    } finally {
        frm.Cursor = Cursors.Default;
        toolButtons["guardar"].Enabled = true;
    }
}

// ═══════════════════ EVENTOS ═══════════════════
void WireTool(string key, Action a) {
    var host = toolButtons[key];
    EventHandler h = (_, __) => { try { a(); } catch (Exception ex) { ctx.Msg(ex.Message, "Error"); } };
    host.Click += h;
    foreach (Control ch in host.Controls) ch.Click += h;
}
WireTool("guardar",  () => CrearFactura());
WireTool("cancelar", () => frm.Close());
WireTool("limpiar",  () => { if (ctx.Confirm("¿Restablecer las cantidades a lo pendiente y limpiar comentarios?")) LimpiarTodo(); });

// OJO (bug real, encontrado en Recepción de Compra): refrescar el grid DENTRO del mismo evento
// de checkbox/combo puede lanzar una excepción reentrante de WinForms. Se difiere con
// BeginInvoke -- ver MANUAL.md #11.
grid.CellEndEdit += (_, ev) => {
    if (ev.RowIndex < 0 || ev.RowIndex >= partidasAFacturar.Count) return;
    var it = partidasAFacturar[ev.RowIndex];
    string col = grid.Columns[ev.ColumnIndex].Name;
    try {
        if (col == "Cantidad") it.Qty = Convert.ToDouble(grid.Rows[ev.RowIndex].Cells["Cantidad"].Value ?? it.Qty);
        else if (col == "Precio") it.Precio = Convert.ToDouble(grid.Rows[ev.RowIndex].Cells["Precio"].Value ?? it.Precio);
        else if (col == "DescPerc") it.DescuentoPerc = Convert.ToDouble(grid.Rows[ev.RowIndex].Cells["DescPerc"].Value ?? it.DescuentoPerc * 100) / 100.0;
        else if (col == "Impuesto") {
            var opt = grid.Rows[ev.RowIndex].Cells["Impuesto"].Value as Opt;
            if (opt != null) { it.TaxTypeId = opt.Val; it.TaxPerc = taxPercByType.ContainsKey(opt.Val) ? taxPercByType[opt.Val] : 0; }
        }
    } catch { }
    if (it.Qty < 0) it.Qty = 0;
    if (it.Qty > it.Pendiente) it.Qty = it.Pendiente;
    if (it.DescuentoPerc < 0) it.DescuentoPerc = 0;
    if (it.DescuentoPerc > 1) it.DescuentoPerc = 1;
    grid.BeginInvoke((Action)(() => RefreshGrid()));
};
grid.CellContentClick += (_, ev) => {
    if (ev.RowIndex < 0 || ev.RowIndex >= partidasAFacturar.Count) return;
    if (grid.Columns[ev.ColumnIndex].Name != "Incluir") return;
    grid.BeginInvoke((Action)(() => {
        grid.EndEdit();
        if (ev.RowIndex >= partidasAFacturar.Count) return;
        var it = partidasAFacturar[ev.RowIndex];
        bool marcado = Convert.ToBoolean(grid.Rows[ev.RowIndex].Cells["Incluir"].Value ?? true);
        it.Qty = marcado ? (it.Qty <= 0 ? it.Pendiente : it.Qty) : 0;
        RefreshGrid();
    }));
};

frm.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.F5) { CrearFactura(); ev.Handled = true; }
    else if (ev.KeyCode == Keys.Escape) { frm.Close(); ev.Handled = true; }
};

// ═══════════════════ CLASES ═══════════════════
class Opt {
    public string Txt; public int Val;
    public Opt(string t, int v) { Txt = t; Val = v; }
    public override string ToString() => Txt;
}
// Una partida PENDIENTE de UNA sola Orden de Compra (antes de consolidar por producto).
class Item {
    public int PID; public int SourceItemId; public string OcFolio;
    public string Key; public string Desc; public string Unit;
    public int TaxTypeId; public double TaxPerc; public double Precio; public double DescuentoPerc;
    public double Pendiente;
}
// Una fila del grid "Partidas a facturar": un producto, posiblemente sumado de VARIAS OC.
class PartidaConsolidada {
    public int PID; public string Key; public string Desc; public string Unit;
    public int TaxTypeId; public double TaxPerc; public double Precio; public double DescuentoPerc;
    public double Pendiente; public double Qty;
    public string OcsResumen;
    public List<Item> Fuentes = new List<Item>();
}

// ═══════════════════ ARRANQUE: MODELESS ═══════════════════
PrecargarFolio();
CargarPartidasPendientes();
frm.Show();
