// lang: csharp
using System;
using System.Drawing;
using System.Windows.Forms;
using System.Collections.Generic;
using System.Linq;

// PLANTILLA_EJEMPLO_FACTURA_COMPRA_CSHARP.ctx
// Ejemplo comunitario completo: transforma una o varias Órdenes de Compra SELECCIONADAS EN EL
// GRID de Comercial (módulo 183) en una Factura de Compra (módulo 152).
//
// A diferencia de Recepción de Compra (que arranca con un buscador de proveedor DENTRO de la
// ventana), aquí el origen es ctx.GetSelectedIds(): el usuario ya seleccionó 1+ filas en la
// lista nativa de Órdenes de Compra (Ctrl+clic) ANTES de darle a este botón.
//
// Perfil de encabezado verificado contra una base de datos real:
// - ModuleID=152, DocumentTypeID=5, DocRecipientID=2.
// - Perfil de encabezado: DepotIDFrom=0, StatusDeliveryID=0 (a diferencia de OC=3), Campaign/
//   CostCenter/Project=NULL.
// - TaxTypeID/TaxPerc se fijan POR PARTIDA (la FC no siempre hereda el impuesto del producto).
// - NO afecta inventario -> SIN AffectStockNEW (a diferencia de Recepción).
// - Contabilidad (accPoliza/accPolizaTransaccion) la genera Save() SOLO -- no hay que tocarla.
// - PaymentAgenda: NuevoDocumento crea un placeholder Amount=0 que Save() no corrige bien
//   (usa el caché interno de XEngine, no la BD) -- hay que regenerarlo A MANO después de Save
//   con los porcentajes reales de engPaymentTermDetail. Ver RegenerarPaymentAgenda() abajo.
//
// N Órdenes de Compra -> 1 Factura: igual que en Recepción de Compra, el vínculo real se hace
// por PARTIDA (docDocumentItem.SourceDocumentItemID -> DocumentItemID de la OC), no por un solo
// campo de encabezado -- así "cuánto ya se facturó" de cada OC se calcula bien aunque una
// factura mezcle partidas de varias OC. Cálculo PROPIO (no hay vista nativa equivalente a
// vwLBSProductsToDeliver para facturación -- ver MANUAL.md #12).
//
// Basado en la captura real del laboratorio y el esquema real de la base de datos.

// ═══════════════════ DATOS INICIALES ═══════════════════
