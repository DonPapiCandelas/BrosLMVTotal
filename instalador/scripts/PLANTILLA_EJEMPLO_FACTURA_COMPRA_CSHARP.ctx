DataGridViewColumn Col(string name, string header, int width, bool readOnly, DataGridViewContentAlignment align = DataGridViewContentAlignment.MiddleLeft, string fmt = null, bool chk = false, bool combo = false, object[] comboItems = null) {
    DataGridViewColumn c;
    if (chk) c = new DataGridViewCheckBoxColumn { Name = name, HeaderText = header, Width = width };
    else if (combo) {
        var cc = new DataGridViewComboBoxColumn { Name = name, HeaderText = header, Width = width, FlatStyle = FlatStyle.Flat, DisplayStyle = DataGridViewComboBoxDisplayStyle.DropDownButton };
        if (comboItems != null) cc.Items.AddRange(comboItems);
        c = cc;
    } else c = new DataGridViewTextBoxColumn { Name = name, HeaderText = header, Width = width, ReadOnly = readOnly };
    if (!chk && !combo) { c.DefaultCellStyle.Alignment = align; if (fmt != null) c.DefaultCellStyle.Format = fmt; }
    grid.Columns.Add(c);
    return c;
}
