Panel CreateGroup(string title, int x, int y, int w, int h, Control parent) {
    var p = new Panel { Location = new Point(x, y), Size = new Size(w, h), BackColor = C_PANEL, Parent = parent };
    p.Paint += (s, e) => {
        var g = e.Graphics;
        g.DrawRectangle(new Pen(C_BORDER), 0, 0, w - 1, h - 1);
        g.FillRectangle(new SolidBrush(C_HEADER), 1, 1, w - 2, 28);
        g.DrawLine(new Pen(C_BORDER), 0, 29, w, 29);
        g.DrawString(title, F_H2, new SolidBrush(C_TEXT), new PointF(10, 5));
    };
    return p;
}
Label Lbl(string txt, int x, int y, Control p) {
    return new Label { Text = txt, Location = new Point(x, y), Font = F_BODY, AutoSize = true, Parent = p };
}
void SelectByVal(ComboBox cbo, int val) {
    for (int i = 0; i < cbo.Items.Count; i++)
        if ((cbo.Items[i] as Opt)?.Val == val) { cbo.SelectedIndex = i; return; }
    if (cbo.Items.Count > 0) cbo.SelectedIndex = 0;
}
