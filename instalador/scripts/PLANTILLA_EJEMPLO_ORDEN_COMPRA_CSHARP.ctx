// lang: csharp
using System;
using System.Drawing;
using System.Windows.Forms;
using System.Collections.Generic;
using System.Linq;

// PLANTILLA_EJEMPLO_ORDEN_COMPRA_CSHARP.ctx
// Ejemplo comunitario completo: crea una Orden de Compra real (módulo 183).
//
// Diferencia clave frente a "Ejemplo Premium - C# WinForms" (Requisición, módulo 1040):
// una Orden de Compra SÍ compromete un PRECIO por partida (es un acuerdo de compra con
// el proveedor, no solo una solicitud interna) y captura la FECHA DE ENTREGA esperada.
//
// Que enseña esta plantilla (además de lo ya cubierto por la Requisición):
// 1. Capturar precio unitario por partida y pasarlo a ctx.erp.AgregarArticulo.
// 2. Fecha de entrega esperada (DateDelivery) además de la fecha del documento.
// 3. Subtotal estimado en vivo (informativo; el total real lo calcula RecalcCompleto).
//
// Regla de fidelidad: la Orden de Compra (módulo 183) NO afecta inventario -- eso
// pasa hasta la Recepción de Compra (módulo 184). Por eso este script NO llama
// AffectStockNEW. Ver MANUAL.md #10 "Ventanas WinForms: modeless" para las reglas
// de por qué esta ventana es Show() (modeless) y por qué cada manejador que hace SQL
// necesita su propio try/catch.

// ═══════════════════ DATOS INICIALES ═══════════════════
var almacenes = ctx.Query("SELECT DepotID, DepotName FROM orgDepot WHERE DeletedOn IS NULL ORDER BY DepotName");
var proveedores = ctx.Query(@"
    SELECT be.BusinessEntityID, be.OfficialName,
           ISNULL(m.OfficialNumber,'') AS RFC
    FROM orgBusinessEntity be
    INNER JOIN orgSupplier s ON s.BusinessEntityID=be.BusinessEntityID
    LEFT JOIN orgBusinessEntityMainInfo m ON m.BusinessEntityID=be.BusinessEntityID
    WHERE be.DeletedOn IS NULL
    ORDER BY be.OfficialName");
var monedas = ctx.Query("SELECT CurrencyID, IntlSymbol, Currency, Rate FROM vwLBSCurrencyList ORDER BY CurrencyID");
var condiciones = ctx.Query("SELECT PaymentTermID, PaymentTermName FROM vwLBSPaymentTermList WHERE Buys=1 AND Deleted=0 ORDER BY PaymentTermID");
// Catálogo de impuestos (misma vista que usa LBS para el combo/listado nativo),
// con su porcentaje real (vwLBSTaxPerc) para poder calcular el total con impuestos aquí mismo.
var impuestos = ctx.Query(@"
    SELECT t.TaxTypeID, t.TaxTypeName, ISNULL(tp.IVA_Perc,0) AS IVA_Perc
    FROM vwLBSTaxType t LEFT JOIN vwLBSTaxPerc tp ON tp.TaxTypeID = t.TaxTypeID
    ORDER BY t.TaxTypeName");

var partidas = new List<Item>();
var provAll = new List<Opt>();
var curRate = new Dictionary<int, double>();
var taxPercByType = new Dictionary<int, double>();
var monedaPalabra = new Dictionary<int, string>();
Prod productoSeleccionado = null;
bool suspenderBusqueda = false;
bool suspenderProv = false;

