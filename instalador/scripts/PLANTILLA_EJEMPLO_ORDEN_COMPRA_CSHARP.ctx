    string cur = Convert.ToString(m["Currency"] ?? "").ToUpperInvariant();
    monedaPalabra[cid] = cur.Contains("PESO") ? "PESOS" : cur.Contains("DOLAR") || cur.Contains("DÓLAR") ? "DÓLARES"
        : cur.Contains("EURO") ? "EUROS" : (cur.Length > 0 ? cur + "S" : "PESOS");
}
