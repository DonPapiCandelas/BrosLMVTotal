DataGridViewTextBoxColumn Col(string name, string header, int width, bool readOnly, DataGridViewContentAlignment align = DataGridViewContentAlignment.MiddleLeft, string fmt = null) {
    var c = new DataGridViewTextBoxColumn { Name = name, HeaderText = header, Width = width, ReadOnly = readOnly };
    c.DefaultCellStyle.Alignment = align;
    if (fmt != null) c.DefaultCellStyle.Format = fmt;
    grid.Columns.Add(c);
    return c;
}
