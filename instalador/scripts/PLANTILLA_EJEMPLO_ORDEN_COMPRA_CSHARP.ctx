// ═══════════════════ LÓGICA DE DIBUJO DE LA LISTA ═══════════════════
lstMatch.DrawItem += (_, ev) => {
    if (ev.Index < 0) return;
    var p = lstMatch.Items[ev.Index] as Prod;
    bool sel = (ev.State & DrawItemState.Selected) == DrawItemState.Selected;
    ev.Graphics.FillRectangle(new SolidBrush(sel ? C_BLUE_SEL : C_PANEL), ev.Bounds);
    if (p == null) return;
    var r = ev.Bounds;
    using (var brText = new SolidBrush(C_TEXT))
    using (var brMuted = new SolidBrush(C_MUTED))
    using (var keyFont = new Font("Segoe UI", 9f, FontStyle.Bold)) {
        ev.Graphics.DrawString(p.Key, keyFont, brText, r.Left + 10, r.Top + 6);
        ev.Graphics.DrawString(p.Desc, F_BODY, brText, new RectangleF(r.Left + 120, r.Top + 6, Math.Max(180, r.Width - 130), 18));
        ev.Graphics.DrawString("Unidad " + p.Unit + " · Exist: " + p.Stock.ToString("N2"), F_SM, brMuted, r.Left + 120, r.Top + 24);
    }
};

// ═══════════════════ LÓGICA CORE ═══════════════════
int DepotSel() { var s = cboDep.SelectedItem as Opt; return s != null ? s.Val : 1; }
int ProvSel() {
    var s = cboProv.SelectedItem as Opt;
    if (s != null) return s.Val;
    string t = (cboProv.Text ?? "").Trim();
    var m = provAll.FirstOrDefault(o => o.Txt.Equals(t, StringComparison.OrdinalIgnoreCase));
    return m != null ? m.Val : 0;
}

void ActualizarProveedor() {
    var s = cboProv.SelectedItem as Opt;
    if (s == null) {
        string t = (cboProv.Text ?? "").Trim();
        s = provAll.FirstOrDefault(o => o.Txt.Equals(t, StringComparison.OrdinalIgnoreCase));
    }
    lblRfc.Text = (s != null && !string.IsNullOrWhiteSpace(s.Extra)) ? s.Extra : (s != null ? "(sin RFC)" : "");
}

void PrecargarFolio() {
    try {
        string pre = ctx.erp.GetFolioPrefix(183, DepotSel());
        string fol = ctx.erp.GetNextFolio(183, pre, DepotSel());
        txtSerie.Text = pre ?? "";
        txtFolio.Text = fol ?? "";
    } catch { txtSerie.Text = "OC"; txtFolio.Text = ""; }
}

void OcultarResultados() { pnlDrop.Visible = false; }

void Buscar(string query) {
    string q = (query ?? "").Trim();
    if (q.Length == 0) { lstMatch.Items.Clear(); OcultarResultados(); return; }

    string safe = q.Replace("'", "''");
    string filtro = q == "#" ? "" : "AND (p.ProductKey LIKE '%" + safe + "%' OR p.ProductName LIKE '%" + safe + "%') ";
    string limite = q == "#" ? "TOP 300" : "TOP 80";

    // Ventana MODELESS: un error aquí ya no lo atrapa el try/catch del script (que
    // terminó apenas se mostró la ventana). Sin este try/catch, un error de SQL
    // tumbaría Comercial completo, no solo esta ventana. (MANUAL.md #10)
    List<Dictionary<string, object>> rows;
    try {
        rows = ctx.Query(
            "SELECT " + limite + " p.ProductID, p.ProductKey, p.ProductName, p.Unit, p.TaxTypeID, " +
            "ISNULL((SELECT SUM(Quantity) FROM orgProductKardex k WHERE k.ProductID=p.ProductID AND k.DepotID=" + DepotSel() + " AND k.Cancelled=0),0) AS Stock " +
            "FROM orgProduct p WHERE p.DeletedOn IS NULL AND p.TaxTypeID IS NOT NULL AND p.TaxTypeID > 0 " +
            filtro + "ORDER BY p.ProductName");
    } catch (Exception ex) {
        ctx.Msg("Error al buscar productos: " + ex.Message, "Error");
        OcultarResultados();
        return;
    }

    lstMatch.BeginUpdate();
    lstMatch.Items.Clear();
    foreach (var r in rows) {
        lstMatch.Items.Add(new Prod {
            PID = Convert.ToInt32(r["ProductID"]),
            Key = Convert.ToString(r["ProductKey"]),
            Desc = Convert.ToString(r["ProductName"]),
            Unit = Convert.ToString(r["Unit"]),
            Stock = Convert.ToDouble(r["Stock"] ?? 0),
            TaxTypeId = Convert.ToInt32(r["TaxTypeID"] ?? 0)
        });
    }
    lstMatch.EndUpdate();

    if (lstMatch.Items.Count == 0) {
        OcultarResultados();
        ctx.Msg("No se encontraron productos con esa búsqueda.");
        return;
    }
    lstMatch.SelectedIndex = 0;
    int alto = Math.Min(lstMatch.Items.Count * lstMatch.ItemHeight + 4, 280);
    pnlDrop.SetBounds(grpPart.Left + txtProducto.Left, grpPart.Top + txtProducto.Bottom + 2, 600, alto);
    pnlDrop.Visible = true;
    pnlDrop.BringToFront();
}

void SeleccionarProducto() {
    var p = lstMatch.SelectedItem as Prod;
    if (p == null) return;
    productoSeleccionado = p;
    suspenderBusqueda = true;
    txtProducto.Text = p.Key + " — " + p.Desc;
    txtProducto.SelectionStart = txtProducto.TextLength;
    suspenderBusqueda = false;
    // Precarga el impuesto del catálogo de productos; el usuario lo puede cambiar
    // antes de agregar (SelectByVal ya cae al primero si no encuentra el TaxTypeID).
    SelectByVal(cboImpuesto, p.TaxTypeId);
    OcultarResultados();
    nudCantidad.Focus();
}

void RefreshGrid() {
    grid.Rows.Clear();
    double subtotal = 0, descuentoTotal = 0, impuestosTotal = 0;
    foreach (var it in partidas) {
        // Importe = cantidad x precio (igual que el nativo: Total en docDocumentItem NO
        // resta el descuento; el descuento se aplica aparte al recalcular el documento).
        double importe = it.Qty * it.Precio;
        double descMonto = importe * it.DescuentoPerc;
        double neto = importe - descMonto;
        double impMonto = neto * it.TaxPerc;
        subtotal += importe;
        descuentoTotal += descMonto;
        impuestosTotal += impMonto;
        grid.Rows.Add(it.PID, it.Key, it.Desc, it.Unit, it.Qty, it.Precio, it.TaxLabel, it.DescuentoPerc * 100, importe);
    }
    double granTotal = subtotal - descuentoTotal + impuestosTotal;
    pnlEmpty.Visible = partidas.Count == 0;
    lblTotalPartidas.Text = "Total de partidas: " + partidas.Count;
    lblSubtotal.Text = "Subtotal estimado: $" + subtotal.ToString("N2");

    lblTSubtotal.Text = "$" + subtotal.ToString("N2");
    lblTDescuento.Text = "-$" + descuentoTotal.ToString("N2");
    lblTImpuestos.Text = "$" + impuestosTotal.ToString("N2");
    lblTTotal.Text = "$" + granTotal.ToString("N2");
    int monedaId = (cboMoneda.SelectedItem as Opt)?.Val ?? 3;
    string palabra = monedaPalabra.ContainsKey(monedaId) ? monedaPalabra[monedaId] : "PESOS";
    string sufijo = monedaId == 3 ? " M.N." : "";
    lblTotalLetra.Text = "SON: " + NumeroALetras(granTotal, palabra) + sufijo;
}

void LimpiarCaptura() {
    productoSeleccionado = null;
    suspenderBusqueda = true;
    txtProducto.Clear();
    suspenderBusqueda = false;
    nudCantidad.Value = 1M;
    nudPrecio.Value = 0M;
    nudDescuento.Value = 0M;
    txtProducto.Focus();
}

void AgregarProducto() {
    if (productoSeleccionado == null) {
        if (pnlDrop.Visible && lstMatch.SelectedItem != null) SeleccionarProducto();
        else { ctx.Msg("Busca y selecciona un producto."); txtProducto.Focus(); return; }
    }
    double cant = Convert.ToDouble(nudCantidad.Value);
    double precio = Convert.ToDouble(nudPrecio.Value);
    double descuento = Convert.ToDouble(nudDescuento.Value) / 100.0; // fracción (5% -> 0.05)
    var impSel = cboImpuesto.SelectedItem as Opt;
    int taxTypeId = impSel?.Val ?? 0;
    string taxLabel = impSel?.Txt ?? "";
    double taxPerc = taxPercByType.ContainsKey(taxTypeId) ? taxPercByType[taxTypeId] : 0;
    var p = productoSeleccionado;
    var ext = partidas.FirstOrDefault(z => z.PID == p.PID);
    if (ext != null) {
        ext.Qty += cant;
        if (precio > 0) ext.Precio = precio;
        ext.TaxTypeId = taxTypeId; ext.TaxLabel = taxLabel; ext.DescuentoPerc = descuento; ext.TaxPerc = taxPerc;
    }
    else partidas.Add(new Item {
        PID = p.PID, Key = p.Key, Desc = p.Desc, Unit = p.Unit, Qty = cant, Precio = precio,
        TaxTypeId = taxTypeId, TaxLabel = taxLabel, DescuentoPerc = descuento, TaxPerc = taxPerc
    });
    RefreshGrid();
    LimpiarCaptura();
}

void LimpiarTodo() {
    partidas.Clear();
    RefreshGrid();
    LimpiarCaptura();
    txtObs.Clear();
    PrecargarFolio();
}

// ═══════════════════ CREAR EN CONTPAQI ═══════════════════
void CrearOrdenCompra(bool nueva) {
    int be = ProvSel();
    if (be == 0) { ctx.Msg("Selecciona un proveedor."); return; }
    if (partidas.Count == 0) { ctx.Msg("Agrega al menos un producto."); return; }
    if (partidas.Any(p => p.Precio <= 0) &&
        !ctx.Confirm("Hay partidas con precio en $0.00. ¿Continuar de todos modos?")) return;

    long supplierID = Convert.ToInt64(ctx.Scalar("SELECT SupplierID FROM orgSupplier WHERE BusinessEntityID=" + be));
    if (!ctx.Confirm("¿Crear orden de compra con " + partidas.Count + " producto" + (partidas.Count == 1 ? "" : "s") + "?")) return;

    frm.Cursor = Cursors.WaitCursor;
    var btnG = toolButtons["guardar"]; btnG.Enabled = false;
    try {
        int dep = DepotSel();
        int monedaId = (cboMoneda.SelectedItem as Opt)?.Val ?? 3;
        int condId = (cboCond.SelectedItem as Opt)?.Val ?? 0;
        double rate = curRate.ContainsKey(monedaId) ? curRate[monedaId] : 1;

        int doc = ctx.erp.NuevoDocumento(183, dep, be); // 183 = Orden de Compra
        if (doc <= 0 || !string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("NuevoDocumento: " + ctx.erp.LastError);

        // Moneda + condición de pago + fecha + entrega esperada + comentarios
        ctx.NonQuery(
            "UPDATE docDocument SET DepotIDFrom=0, UserID=0, " +
            "CurrencyID=" + monedaId + ", Rate=" + rate.ToString(System.Globalization.CultureInfo.InvariantCulture) + ", " +
            "PaymentTermID=" + condId + ", " +
            "DateDocument='" + dtFecha.Value.ToString("yyyyMMdd") + "', " +
            "DateDelivery='" + dtEntrega.Value.ToString("yyyyMMdd") + "', " +
            "Comments='" + txtObs.Text.Replace("'", "''") + "' WHERE DocumentID=" + doc);

        // Folio manual (si el usuario lo modificó)
        string folioManual = (txtFolio.Text ?? "").Trim();
        if (folioManual.Length > 0)
            ctx.NonQuery("UPDATE docDocument SET Folio=N'" + folioManual.Replace("'", "''") + "' WHERE DocumentID=" + doc);

        foreach (var it in partidas) {
            // taxTypeIdOverride: el impuesto elegido en la ventana (por defecto el del
            // catálogo, pero pudo cambiarse). descuentoPerc ya viene en fracción.
            ctx.erp.AgregarArticulo(doc, it.PID, it.Qty, it.Precio, -1, it.TaxTypeId, it.DescuentoPerc);
            if (!string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("AgregarArticulo: " + ctx.erp.LastError);
            // Vincula/actualiza el precio negociado con el proveedor (orgProductSupplier).
            ctx.NonQuery(
                "IF NOT EXISTS (SELECT 1 FROM orgProductSupplier WHERE ProductID=" + it.PID + " AND SupplierID=" + supplierID + ") " +
                "INSERT INTO orgProductSupplier (ProductID, SupplierID, CostPrice, CurrencyID, OrderNumber) VALUES (" + it.PID + ", " + supplierID + ", " + it.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture) + ", " + monedaId + ", 0) " +
                "ELSE UPDATE orgProductSupplier SET CostPrice=" + it.Precio.ToString(System.Globalization.CultureInfo.InvariantCulture) + " WHERE ProductID=" + it.PID + " AND SupplierID=" + supplierID);
        }

        ctx.erp.RecalcCompleto(doc);
        if (!string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("RecalcCompleto: " + ctx.erp.LastError);
        // Nota: NO se llama AffectStockNEW -- la Orden de Compra NO afecta inventario
        // (eso ocurre hasta la Recepción de Compra, módulo 184).
        ctx.erp.Save(doc);
        if (!string.IsNullOrEmpty(ctx.erp.LastError)) throw new Exception("Save: " + ctx.erp.LastError);
        // Sin esto, el documento queda con estatus de entrega "No Aplica" en el grid
        // nativo aunque el documento esté bien creado -- RecalcCompleto NO lo calcula.
        try { ctx.erp.UpdateStatusDelivery(doc); } catch { }
        try { ctx.erp.RefreshGrid(); } catch { }

        ctx.Msg("Orden de compra " + doc + " creada exitosamente.", "OK");
        if (nueva) { LimpiarTodo(); }
        else frm.Close();
    } catch (Exception ex) {
        ctx.Msg(ex.Message, "Error");
    } finally {
        frm.Cursor = Cursors.Default;
        toolButtons["guardar"].Enabled = true;
    }
}

// ═══════════════════ NÚMERO A LETRAS (para el total, estilo comprobante mexicano) ═══════════════════
string[] UNIDADES = { "", "UNO", "DOS", "TRES", "CUATRO", "CINCO", "SEIS", "SIETE", "OCHO", "NUEVE", "DIEZ",
    "ONCE", "DOCE", "TRECE", "CATORCE", "QUINCE", "DIECISÉIS", "DIECISIETE", "DIECIOCHO", "DIECINUEVE", "VEINTE" };
string[] DECENAS = { "", "", "VEINTE", "TREINTA", "CUARENTA", "CINCUENTA", "SESENTA", "SETENTA", "OCHENTA", "NOVENTA" };
string[] VEINTI = { "VEINTIUNO", "VEINTIDÓS", "VEINTITRÉS", "VEINTICUATRO", "VEINTICINCO", "VEINTISÉIS", "VEINTISIETE", "VEINTIOCHO", "VEINTINUEVE" };
string[] CENTENAS = { "", "CIENTO", "DOSCIENTOS", "TRESCIENTOS", "CUATROCIENTOS", "QUINIENTOS",
    "SEISCIENTOS", "SETECIENTOS", "OCHOCIENTOS", "NOVECIENTOS" };

string Centenas_(int n) { // 0..999
    if (n == 0) return "";
    if (n == 100) return "CIEN";
    string s = "";
    int c = n / 100, r = n % 100;
    if (c > 0) s += CENTENAS[c] + " ";
    if (r > 0) {
        if (r <= 20) s += UNIDADES[r];
        else {
            int d = r / 10, u = r % 10;
            if (d == 2 && u > 0) s += VEINTI[u - 1];
            else { s += DECENAS[d]; if (u > 0) s += " Y " + UNIDADES[u]; }
        }
    }
    return s.Trim();
}
string EnLetras(long n) { // 0..999,999,999
    if (n == 0) return "CERO";
    string resultado = "";
    long millones = n / 1000000; n %= 1000000;
    long miles = n / 1000; n %= 1000;
    long resto = n;
    if (millones > 0) resultado += (millones == 1 ? "UN MILLÓN " : Centenas_((int)millones) + " MILLONES ");
    if (miles > 0) resultado += (miles == 1 ? "MIL " : Centenas_((int)miles) + " MIL ");
    if (resto > 0) resultado += Centenas_((int)resto);
    resultado = resultado.Trim();
    if (resultado.EndsWith("UNO")) resultado = resultado.Substring(0, resultado.Length - 3) + "UN"; // UN peso, no UNO peso
    return resultado;
}
string NumeroALetras(double valor, string moneda) {
    if (valor < 0) valor = 0;
    long entero = (long)Math.Floor(valor);
    int centavos = (int)Math.Round((valor - entero) * 100);
    return EnLetras(entero) + " " + moneda + " " + centavos.ToString("00") + "/100";
}

// ═══════════════════ DETALLE DE PRODUCTO (doble clic en una partida) ═══════════════════
void MostrarDetalleProducto(int pid) {
    Dictionary<string, object> info = null;
    try {
        var rows = ctx.Query(
            "SELECT ProductKey, ProductName, ProductDescription, Unit, UnitSale, UnitBuy, CostPrice, PriceList, " +
            "TaxTypeID, TaxPerc, Category1, Category2, Category3, Category4, BarCode, SKUCode, QtyMinimum, QtyMax, " +
            "ProductIsService, AvailableForSale FROM orgProduct WHERE ProductID=" + pid);
        if (rows.Count > 0) info = rows[0];
    } catch (Exception ex) { ctx.Msg("Error al leer el producto: " + ex.Message, "Error"); return; }
    if (info == null) { ctx.Msg("No se encontró el producto."); return; }

    List<Dictionary<string, object>> existencias, listasPrecio, preciosProveedor;
    try {
        existencias = ctx.Query(
            "SELECT d.DepotName, ISNULL(SUM(k.Quantity),0) AS Existencia " +
            "FROM orgDepot d LEFT JOIN orgProductKardex k ON k.DepotID=d.DepotID AND k.ProductID=" + pid + " AND k.Cancelled=0 " +
            "WHERE d.DeletedOn IS NULL GROUP BY d.DepotName ORDER BY d.DepotName");
    } catch { existencias = new List<Dictionary<string, object>>(); }
    try {
        listasPrecio = ctx.Query(
            "SELECT pl.PriceListName, ppl.Price FROM orgProductPriceList ppl " +
            "INNER JOIN orgPriceList pl ON pl.PriceListID=ppl.PriceListID " +
            "WHERE ppl.ProductID=" + pid + " AND pl.DeletedOn IS NULL ORDER BY pl.PriceListName");
    } catch { listasPrecio = new List<Dictionary<string, object>>(); }
    try {
        preciosProveedor = ctx.Query(
            "SELECT be.OfficialName, ps.CostPrice, ps.RefSupplier FROM orgProductSupplier ps " +
            "INNER JOIN orgSupplier s ON s.SupplierID=ps.SupplierID " +
            "INNER JOIN orgBusinessEntity be ON be.BusinessEntityID=s.BusinessEntityID " +
            "WHERE ps.ProductID=" + pid + " ORDER BY ps.CostPrice");
    } catch { preciosProveedor = new List<Dictionary<string, object>>(); }

    var det = new Form { Text = "Detalle de producto", Size = new Size(700, 800), StartPosition = FormStartPosition.CenterParent, BackColor = C_BG, MinimizeBox = false, MaximizeBox = false, FormBorderStyle = FormBorderStyle.FixedDialog, AutoScaleMode = AutoScaleMode.None };

    string Val(string k) => info.ContainsKey(k) && info[k] != null ? Convert.ToString(info[k]) : "";
    double taxPercInfo = 0; try { taxPercInfo = Convert.ToDouble(info["TaxPerc"] ?? 0); } catch { }

    var grpGen = CreateGroup("Datos generales", 10, 10, 660, 185, det);
    Lbl("Clave:", 15, 38, grpGen); Lbl(Val("ProductKey"), 110, 38, grpGen).Font = F_H2;
    Lbl("Nombre:", 340, 38, grpGen); Lbl(Val("ProductName"), 410, 38, grpGen).Font = F_H2;
    var lblDescLarga = new Label { Text = Val("ProductDescription"), Location = new Point(110, 64), Size = new Size(535, 34), Font = F_SM, ForeColor = C_MUTED, Parent = grpGen };
    Lbl("Descripción:", 15, 64, grpGen);
    Lbl("Unidad:", 15, 108, grpGen); Lbl(Val("Unit"), 110, 108, grpGen);
    Lbl("U. venta:", 250, 108, grpGen); Lbl(Val("UnitSale"), 335, 108, grpGen);
    Lbl("U. compra:", 460, 108, grpGen); Lbl(Val("UnitBuy"), 555, 108, grpGen);
    Lbl("Costo:", 15, 138, grpGen); Lbl("$" + Convert.ToDouble(info["CostPrice"] ?? 0).ToString("N2"), 110, 138, grpGen);
    Lbl("Precio lista:", 250, 138, grpGen); Lbl("$" + Convert.ToDouble(info["PriceList"] ?? 0).ToString("N2"), 335, 138, grpGen);
    Lbl("Impuesto:", 460, 138, grpGen); Lbl((taxPercInfo * 100).ToString("N2") + "%", 555, 138, grpGen);

    var grpClas = CreateGroup("Clasificaciones", 10, 205, 660, 90, det);
    Lbl("Categoría 1:", 15, 38, grpClas); Lbl(Val("Category1"), 130, 38, grpClas).Font = F_H2;
    Lbl("Categoría 2:", 355, 38, grpClas); Lbl(Val("Category2"), 470, 38, grpClas).Font = F_H2;
    Lbl("Categoría 3:", 15, 63, grpClas); Lbl(Val("Category3"), 130, 63, grpClas).Font = F_H2;
    Lbl("Categoría 4:", 355, 63, grpClas); Lbl(Val("Category4"), 470, 63, grpClas).Font = F_H2;

    DataGridView MiniGrid(int y, int h, string[] nombres, string[] encabezados) {
        var g = new DataGridView {
            Location = new Point(15, y), Size = new Size(640, h), BackgroundColor = C_PANEL, BorderStyle = BorderStyle.FixedSingle,
            ColumnHeadersBorderStyle = DataGridViewHeaderBorderStyle.None, EnableHeadersVisualStyles = false,
            RowHeadersVisible = false, AllowUserToAddRows = false, AllowUserToDeleteRows = false, ReadOnly = true,
            SelectionMode = DataGridViewSelectionMode.FullRowSelect, GridColor = C_BORDER, Parent = det
        };
        g.ColumnHeadersDefaultCellStyle.BackColor = C_HEADER;
        g.ColumnHeadersDefaultCellStyle.Font = F_H2;
        g.ColumnHeadersHeight = 26;
        g.RowTemplate.Height = 24;
        for (int i = 0; i < nombres.Length; i++) g.Columns.Add(nombres[i], encabezados[i]);
        g.Columns[nombres.Length - 1].AutoSizeMode = DataGridViewAutoSizeColumnMode.Fill;
        return g;
    }

    int y = 305;
    Lbl("Existencia por almacén", 15, y, det).Font = F_H2;
    var gridExist = MiniGrid(y + 22, 120, new[] { "Depot", "Qty" }, new[] { "ALMACÉN", "EXISTENCIA" });
    foreach (var r in existencias) gridExist.Rows.Add(Convert.ToString(r["DepotName"]), Convert.ToDouble(r["Existencia"] ?? 0).ToString("N2"));
    if (existencias.Count == 0) gridExist.Rows.Add("(sin almacenes)", "");
    y += 22 + 120 + 24;

    Lbl("Listas de precios", 15, y, det).Font = F_H2;
    var gridListas = MiniGrid(y + 22, 100, new[] { "Lista", "Precio" }, new[] { "LISTA DE PRECIOS", "PRECIO" });
    foreach (var r in listasPrecio) gridListas.Rows.Add(Convert.ToString(r["PriceListName"]), "$" + Convert.ToDouble(r["Price"] ?? 0).ToString("N2"));
    if (listasPrecio.Count == 0) gridListas.Rows.Add("(sin listas de precio asignadas)", "");
    y += 22 + 100 + 24;

    Lbl("Precios por proveedor", 15, y, det).Font = F_H2;
    var gridProv = MiniGrid(y + 22, 100, new[] { "Prov", "Ref", "Precio" }, new[] { "PROVEEDOR", "REF. PROVEEDOR", "COSTO" });
    foreach (var r in preciosProveedor) gridProv.Rows.Add(Convert.ToString(r["OfficialName"]), Convert.ToString(r["RefSupplier"] ?? ""), "$" + Convert.ToDouble(r["CostPrice"] ?? 0).ToString("N2"));
    if (preciosProveedor.Count == 0) gridProv.Rows.Add("(sin proveedores registrados)", "", "");
    y += 22 + 100 + 20;

    var btnCerrar = new Button { Text = "Cerrar", Location = new Point(585, y), Size = new Size(90, 30), FlatStyle = FlatStyle.Flat, Font = F_BODY, Parent = det };
    btnCerrar.FlatAppearance.BorderColor = C_BORDER;
    btnCerrar.Click += (_, __) => det.Close();
    det.AcceptButton = btnCerrar;
    det.ClientSize = new Size(700, y + 30 + 20);

    det.ShowDialog(frm);
}

// ═══════════════════ EVENTOS ═══════════════════
void WireTool(string key, Action a) {
    var host = toolButtons[key];
    EventHandler h = (_, __) => { try { a(); } catch (Exception ex) { ctx.Msg(ex.Message, "Error"); } };
    host.Click += h;
    foreach (Control ch in host.Controls) ch.Click += h;
}
WireTool("guardar",  () => CrearOrdenCompra(false));
WireTool("nueva",    () => CrearOrdenCompra(true));
WireTool("cancelar", () => frm.Close());
WireTool("preview",  () => ctx.Msg("Vista previa: en proceso (próxima versión de la plantilla).", "En proceso"));
WireTool("imprimir", () => ctx.Msg("Impresión: en proceso (próxima versión de la plantilla).", "En proceso"));
WireTool("limpiar",  () => { if (partidas.Count == 0 || ctx.Confirm("¿Limpiar todos los campos?")) LimpiarTodo(); });

cboProv.TextUpdate += (_, __) => {
    if (suspenderProv) return;
    string f = cboProv.Text;
    string fu = f.ToUpperInvariant();
    suspenderProv = true;
    cboProv.Items.Clear();
    foreach (var o in provAll)
        if (f.Length == 0 || o.Txt.ToUpperInvariant().Contains(fu) || (o.Extra ?? "").ToUpperInvariant().Contains(fu))
            cboProv.Items.Add(o);
    cboProv.Text = f;
    cboProv.SelectionStart = f.Length;
    cboProv.SelectionLength = 0;
    cboProv.DroppedDown = cboProv.Items.Count > 0;
    Cursor.Current = Cursors.Default;
    cboProv.SelectionStart = f.Length;
    suspenderProv = false;
    ActualizarProveedor();
};
cboProv.SelectedIndexChanged += (_, __) => { if (!suspenderProv) ActualizarProveedor(); };

txtProducto.TextChanged += (_, __) => {
    if (suspenderBusqueda) return;
    productoSeleccionado = null;
    Buscar(txtProducto.Text);
};
btnBuscarProd.Click += (_, __) => {
    string t = (txtProducto.Text ?? "").Trim();
    Buscar(t.Length == 0 ? "#" : t);
    txtProducto.Focus();
};

lstMatch.MouseDoubleClick += (_, __) => SeleccionarProducto();
lstMatch.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Enter) { SeleccionarProducto(); ev.Handled = true; }
    else if (ev.KeyCode == Keys.Escape) { OcultarResultados(); txtProducto.Focus(); ev.Handled = true; }
};
txtProducto.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Down && pnlDrop.Visible) { lstMatch.Focus(); if (lstMatch.SelectedIndex < 0 && lstMatch.Items.Count > 0) lstMatch.SelectedIndex = 0; ev.Handled = true; }
    else if (ev.KeyCode == Keys.Enter) {
        if (pnlDrop.Visible && lstMatch.SelectedItem != null) SeleccionarProducto();
        else if (productoSeleccionado != null) AgregarProducto();
        ev.Handled = true; ev.SuppressKeyPress = true;
    } else if (ev.KeyCode == Keys.Escape) { LimpiarCaptura(); ev.Handled = true; }
};
nudPrecio.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Enter) { AgregarProducto(); ev.Handled = true; ev.SuppressKeyPress = true; }
};
nudCantidad.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.Enter) { AgregarProducto(); ev.Handled = true; ev.SuppressKeyPress = true; }
};

btnAgregar.Click += (_, __) => AgregarProducto();
btnEliminar.Click += (_, __) => {
    if (grid.CurrentRow == null) return;
    int i = grid.CurrentRow.Index;
    if (i >= 0 && i < partidas.Count) { partidas.RemoveAt(i); RefreshGrid(); }
};
cboDep.SelectedIndexChanged += (_, __) => PrecargarFolio();
cboMoneda.SelectedIndexChanged += (_, __) => RefreshGrid(); // el total en letra depende de la moneda elegida

grid.CellDoubleClick += (_, ev) => {
    if (ev.RowIndex < 0 || ev.RowIndex >= partidas.Count) return;
    MostrarDetalleProducto(partidas[ev.RowIndex].PID);
};

// Edición de precio/cantidad/descuento directamente en el grid.
grid.CellEndEdit += (_, ev) => {
    if (ev.RowIndex < 0 || ev.RowIndex >= partidas.Count) return;
    var it = partidas[ev.RowIndex];
    string col = grid.Columns[ev.ColumnIndex].Name;
    try {
        if (col == "Qty") it.Qty = Convert.ToDouble(grid.Rows[ev.RowIndex].Cells["Qty"].Value ?? it.Qty);
        else if (col == "Precio") it.Precio = Convert.ToDouble(grid.Rows[ev.RowIndex].Cells["Precio"].Value ?? it.Precio);
        else if (col == "DescPerc") it.DescuentoPerc = Convert.ToDouble(grid.Rows[ev.RowIndex].Cells["DescPerc"].Value ?? it.DescuentoPerc * 100) / 100.0;
    } catch { }
    if (it.Qty <= 0) it.Qty = 1;
    if (it.Precio < 0) it.Precio = 0;
    if (it.DescuentoPerc < 0) it.DescuentoPerc = 0;
    if (it.DescuentoPerc > 1) it.DescuentoPerc = 1;
    RefreshGrid();
};

// Atajos globales
frm.KeyDown += (_, ev) => {
    if (ev.KeyCode == Keys.F5) { CrearOrdenCompra(false); ev.Handled = true; }
    else if (ev.KeyCode == Keys.Escape && !pnlDrop.Visible) { frm.Close(); ev.Handled = true; }
};

// ═══════════════════ CLASES ═══════════════════
class Opt {
    public string Txt; public int Val; public string Extra;
    public Opt(string t, int v, string e = "") { Txt = t; Val = v; Extra = e; }
    public override string ToString() => Txt;
}
class Item {
    public int PID; public string Key; public string Desc; public string Unit;
    public double Qty; public double Precio;
    public int TaxTypeId; public string TaxLabel = ""; public double DescuentoPerc; // fracción (0.05 = 5%)
    public double TaxPerc; // fracción (0.16 = 16%), para calcular el total con impuestos en esta ventana
}
class Prod { public int PID; public string Key; public string Desc; public string Unit; public double Stock; public int TaxTypeId; }

// ═══════════════════ ARRANQUE: MODELESS ═══════════════════
ActualizarProveedor();
PrecargarFolio();
RefreshGrid();
frm.Show();
