<Window x:Class="BrosLMV.Empresas.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" Width="430" Height="210"
        WindowStartupLocation="CenterScreen" Background="#0B1E33"
        Icon="pack://application:,,,/assets/app_icon.png">
  <Border BorderBrush="#1E3D5C" BorderThickness="1">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
      <Image Source="pack://application:,,,/assets/logo_blanco.png" Height="72" Margin="0,0,0,18" Stretch="Uniform"/>
      <TextBlock Text="Instalando componentes de BrosLMV..." Foreground="White" FontSize="14"
                 HorizontalAlignment="Center" Margin="0,0,0,14"/>
      <ProgressBar IsIndeterminate="True" Width="320" Height="6" Foreground="#2D6FE0" Background="#1E3D5C" BorderThickness="0"/>
    </StackPanel>
  </Border>
</Window>
