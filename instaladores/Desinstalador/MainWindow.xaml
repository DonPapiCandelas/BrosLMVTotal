<Window x:Class="BrosLMV.Desinstalador.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BrosLMV — Desinstalador" Height="760" Width="1100"
        WindowStartupLocation="CenterScreen" Background="#F4F6F9" FontFamily="Segoe UI"
        Icon="pack://application:,,,/assets/app_icon.png">
  <Window.Resources>
    <Style TargetType="Button" x:Key="Danger">
      <Setter Property="Background" Value="#DC2626"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border CornerRadius="6" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style TargetType="Button" x:Key="Ghost">
      <Setter Property="Background" Value="White"/>
      <Setter Property="Foreground" Value="#334155"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="#CBD5E1" BorderThickness="1" Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="250"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- SIDEBAR -->
    <Border Grid.Column="0">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Color="#15324F" Offset="0"/>
          <GradientStop Color="#0B1E33" Offset="1"/>
        </LinearGradientBrush>
      </Border.Background>
      <DockPanel LastChildFill="False">
        <Image DockPanel.Dock="Top" Height="120" Margin="20,28,20,18" Stretch="Uniform"
               Source="pack://application:,,,/assets/logo_blanco.png"/>
        <Border DockPanel.Dock="Top" Background="#5A2330" Margin="12,6" CornerRadius="6">
          <TextBlock Text="🗑   Desinstalar" Foreground="White" FontWeight="SemiBold" Margin="16,12"/>
        </Border>
        <StackPanel DockPanel.Dock="Bottom" Margin="20,16">
          <TextBlock x:Name="lblConnTitle" Text="Sin conexión" Foreground="White" FontWeight="SemiBold"/>
          <TextBlock x:Name="lblConnSrv" Text="" Foreground="#9FB3C8" FontSize="11" Margin="0,2,0,0"/>
          <TextBlock x:Name="lblConnUsr" Text="" Foreground="#9FB3C8" FontSize="11"/>
          <TextBlock x:Name="lblVer" Text="BrosLMV" Foreground="#6E8198" FontSize="11" Margin="0,14,0,0"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- MAIN -->
    <Grid Grid.Column="1" Margin="28,24,28,20">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <StackPanel>
          <TextBlock Text="BrosLMV — Desinstalador" FontSize="24" FontWeight="Bold" Foreground="#16263A"/>
          <TextBlock Text="Quita BrosLMV de las empresas y/o de este equipo." Foreground="#64748B" Margin="0,4,0,0"/>
        </StackPanel>
        <Image Height="44" HorizontalAlignment="Right" VerticalAlignment="Top" Stretch="Uniform"
               Source="pack://application:,,,/assets/logo_mono.png"/>
      </Grid>

      <!-- Aviso -->
      <Border Grid.Row="1" Background="#FEF3F2" CornerRadius="10" BorderBrush="#FECDCA" BorderThickness="1" Padding="16" Margin="0,16,0,0">
        <TextBlock TextWrapping="Wrap" Foreground="#7A271A">
          <Run FontWeight="SemiBold">Atención:</Run>
          <Run Text=" 'Quitar de este equipo' elimina por completo C:\BrosLMV, des-registra el componente y borra el icono. 'Quitar de empresas' elimina el botón y las tablas zzBros* (incluye los scripts guardados) de las empresas seleccionadas. Estas acciones no se pueden deshacer."/>
        </TextBlock>
      </Border>

      <!-- Connection panel -->
      <Border Grid.Row="2" Background="White" CornerRadius="10" BorderBrush="#E6E9EF" BorderThickness="1" Padding="18" Margin="0,16,0,0">
        <StackPanel>
          <TextBlock Text="Conexión a SQL Server (para quitar de empresas)" FontWeight="SemiBold" Foreground="#16263A" Margin="0,0,0,12"/>
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/><ColumnDefinition Width="12"/>
              <ColumnDefinition Width="170"/><ColumnDefinition Width="12"/>
              <ColumnDefinition Width="220"/><ColumnDefinition Width="12"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Servidor\Instancia" Foreground="#64748B" FontSize="11"/>
              <ComboBox x:Name="cbServer" IsEditable="True" Text="localhost\COMPAC2022" Margin="0,3,0,0" Height="32" Padding="6,4" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Text="Usuario" Foreground="#64748B" FontSize="11"/>
              <TextBox x:Name="txtUser" Text="SA" Margin="0,3,0,0" Height="32" Padding="6,5" VerticalContentAlignment="Center"/>
            </StackPanel>
            <StackPanel Grid.Column="4">
              <TextBlock Text="Contraseña" Foreground="#64748B" FontSize="11"/>
              <Grid Margin="0,3,0,0">
                <PasswordBox x:Name="pwdBox" Height="32" Padding="6,5" VerticalContentAlignment="Center"/>
                <TextBox x:Name="pwdPlain" Height="32" Padding="6,5" VerticalContentAlignment="Center" Visibility="Collapsed"/>
                <Button x:Name="btnEye" Content="👁" HorizontalAlignment="Right" Width="30" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="btnEye_Click"/>
              </Grid>
            </StackPanel>
            <Button x:Name="btnConn" Grid.Column="6" Content="Conectar" Style="{StaticResource Ghost}" VerticalAlignment="Bottom" Height="32" Click="btnConn_Click"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Companies -->
      <Border Grid.Row="3" Background="White" CornerRadius="10" BorderBrush="#E6E9EF" BorderThickness="1" Padding="18" Margin="0,16,0,0">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Empresas con BrosLMV instalado" FontWeight="SemiBold" Foreground="#16263A" VerticalAlignment="Center"/>
            <Button x:Name="btnMark" Grid.Column="2" Content="Marcar todas" Style="{StaticResource Ghost}" Click="btnMark_Click"/>
          </Grid>
          <DataGrid x:Name="grid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEF1F5" BorderThickness="0"
                    RowHeight="36" Background="White" RowBackground="White" SelectionMode="Single">
            <DataGrid.Columns>
              <DataGridTemplateColumn Width="46">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <CheckBox IsChecked="{Binding Sel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Empresa (base de datos)" Binding="{Binding DB}" Width="*" IsReadOnly="True"/>
              <DataGridTemplateColumn Header="Estado" Width="200">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                      <TextBlock Text="{Binding EstadoIcon}" Foreground="{Binding EstadoColor}" FontWeight="Bold" FontSize="13" Margin="0,0,7,0"/>
                      <TextBlock Text="{Binding Estado}" Foreground="{Binding EstadoColor}" FontWeight="SemiBold"/>
                    </StackPanel>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- Footer -->
      <Grid Grid.Row="4" Margin="0,14,0,0">
        <TextBlock x:Name="lblFooter" Text="Conéctate para quitar de empresas, o usa 'Quitar de este equipo'." Foreground="#64748B" VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
          <Button x:Name="btnQuitarEmpresas" Content="Quitar de empresas seleccionadas (0)" Style="{StaticResource Ghost}" Margin="0,0,10,0" IsEnabled="False" Click="btnQuitarEmpresas_Click"/>
          <Button x:Name="btnQuitarEquipo" Content="Quitar BrosLMV de este equipo" Style="{StaticResource Danger}" Click="btnQuitarEquipo_Click"/>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Window>
